# Server-only
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Quoted price per generation. MUST equal the on-chain contract min-price
# (min-price-stx / min-price-sbtc). If the env price is higher than the contract
# min, a user could pay the contract min, have it accepted on-chain, and still be
# rejected as "underpaid" — losing funds. Keep them identical (set-prices on-chain).
PRICE_STX=100000   # microSTX (100000 = 0.1 STX)
PRICE_SBTC=100     # sats

# Secret (>=32 chars) that HMAC-signs the history sign-in session cookie, so a
# wallet signs in once instead of on every page. Generate: openssl rand -base64 32
AUTH_SESSION_SECRET=

# LLM provider — defaults to groq (free, no card). Only fill in the key for the
# provider you use. Switch providers with LLM_PROVIDER alone, no code changes.
LLM_PROVIDER=groq                 # groq | gemini | openrouter | ollama
GROQ_API_KEY=gsk_...              # console.groq.com (free)
# GEMINI_API_KEY=AIza...          # aistudio.google.com (free)
# OPENROUTER_API_KEY=sk-or-...    # openrouter.ai (has :free models)
# LLM_MODEL=                      # override the default model (optional)
# LLM_BASE_URL=                   # override the endpoint, e.g. a remote Ollama (optional)

# Public (client-side)
# --- Testnet (default) ---
NEXT_PUBLIC_STACKS_NETWORK=testnet   # testnet | mainnet (match CONTRACT + HIRO_API)
NEXT_PUBLIC_CONTRACT=ST...DEPLOYER.thread-pay
NEXT_PUBLIC_SBTC_CONTRACT=ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT.sbtc-token
NEXT_PUBLIC_HIRO_API=https://api.testnet.hiro.so
# App domain bound into the sign-in message (host only). Defaults to
# threadgogh.vercel.app; set to localhost for local dev.
NEXT_PUBLIC_APP_DOMAIN=threadgogh.vercel.app

# --- Mainnet (switch ALL four together; see .claude/docs/mainnet-deploy.md) ---
# NEXT_PUBLIC_STACKS_NETWORK=mainnet
# NEXT_PUBLIC_CONTRACT=SP...DEPLOYER.thread-pay
# NEXT_PUBLIC_SBTC_CONTRACT=SM3VDXK3WZZSA84XXFKAFAF15NNZX32CTSG82JFQ4.sbtc-token  # verify on docs.hiro.so/sbtc
# NEXT_PUBLIC_HIRO_API=https://api.hiro.so
