# Server-only
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
PRICE_STX=100000
PRICE_SBTC=100

# LLM provider — defaults to groq (free, no card). Only fill in the key for the
# provider you use. Switch providers with LLM_PROVIDER alone, no code changes.
LLM_PROVIDER=groq                 # groq | gemini | openrouter | ollama
GROQ_API_KEY=gsk_...              # console.groq.com (free)
# GEMINI_API_KEY=AIza...          # aistudio.google.com (free)
# OPENROUTER_API_KEY=sk-or-...    # openrouter.ai (has :free models)
# LLM_MODEL=                      # override the default model (optional)
# LLM_BASE_URL=                   # override the endpoint, e.g. a remote Ollama (optional)

# Public (client-side)
NEXT_PUBLIC_STACKS_NETWORK=testnet   # testnet | mainnet (match CONTRACT + HIRO_API)
NEXT_PUBLIC_CONTRACT=ST...DEPLOYER.thread-pay
NEXT_PUBLIC_SBTC_CONTRACT=ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT.sbtc-token
NEXT_PUBLIC_HIRO_API=https://api.testnet.hiro.so
